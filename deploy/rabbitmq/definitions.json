{
  "description": "Enterprise Agent — RabbitMQ 预定义拓扑 (Agent 智能客服)",
  "queues": [
    {
      "name": "agent.inference.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "classic",
        "x-max-priority": 10,
        "x-message-ttl": 300000,
        "x-dead-letter-exchange": "agent.dlx",
        "x-dead-letter-routing-key": "agent.inference.dlq"
      }
    },
    {
      "name": "agent.inference.dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "memory.persist.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "classic",
        "x-message-ttl": 60000,
        "x-dead-letter-exchange": "agent.dlx",
        "x-dead-letter-routing-key": "memory.persist.dlq"
      }
    },
    {
      "name": "memory.persist.dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "rag.index.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "classic",
        "x-max-priority": 5,
        "x-message-ttl": 600000,
        "x-dead-letter-exchange": "agent.dlx",
        "x-dead-letter-routing-key": "rag.index.dlq"
      }
    },
    {
      "name": "rag.index.dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false
    },
    {
      "name": "notify.push.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "classic",
        "x-message-ttl": 300000
      }
    }
  ],
  "exchanges": [
    {
      "name": "agent.tasks",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false
    },
    {
      "name": "agent.dlx",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false
    }
  ],
  "bindings": [
    {
      "source": "agent.tasks",
      "vhost": "/",
      "destination": "agent.inference.queue",
      "destination_type": "queue",
      "routing_key": "agent.inference.*",
      "arguments": {}
    },
    {
      "source": "agent.tasks",
      "vhost": "/",
      "destination": "memory.persist.queue",
      "destination_type": "queue",
      "routing_key": "memory.persist",
      "arguments": {}
    },
    {
      "source": "agent.tasks",
      "vhost": "/",
      "destination": "rag.index.queue",
      "destination_type": "queue",
      "routing_key": "rag.index.*",
      "arguments": {}
    },
    {
      "source": "agent.tasks",
      "vhost": "/",
      "destination": "notify.push.queue",
      "destination_type": "queue",
      "routing_key": "notify.*",
      "arguments": {}
    },
    {
      "source": "agent.dlx",
      "vhost": "/",
      "destination": "agent.inference.dlq",
      "destination_type": "queue",
      "routing_key": "agent.inference.dlq",
      "arguments": {}
    },
    {
      "source": "agent.dlx",
      "vhost": "/",
      "destination": "memory.persist.dlq",
      "destination_type": "queue",
      "routing_key": "memory.persist.dlq",
      "arguments": {}
    },
    {
      "source": "agent.dlx",
      "vhost": "/",
      "destination": "rag.index.dlq",
      "destination_type": "queue",
      "routing_key": "rag.index.dlq",
      "arguments": {}
    }
  ]
}
