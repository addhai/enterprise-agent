# =============================================================================
# Enterprise Agent — Grafana Dashboard (基础版)
# =============================================================================
# 导入方式: Grafana → Dashboards → Import → Upload JSON file
# 数据源: Prometheus (uid: prometheus)
# =============================================================================

{
  "dashboard": {
    "uid": "enterprise-agent",
    "title": "Enterprise Agent — Service Overview",
    "tags": ["enterprise-agent", "ai", "customer-service"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Services Status",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 2},
        "targets": [
          {
            "expr": "count(up == 1) / count(up)",
            "legendFormat": "Uptime Ratio"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.9},
                {"color": "green", "value": 0.99}
              ]
            },
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 2,
        "title": "API Requests per Second",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 2, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{service=\"api\"}[1m])) by (endpoint)",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {"lineWidth": 2, "fillOpacity": 15}
          }
        }
      },
      {
        "id": 3,
        "title": "API Latency (P50/P95/P99)",
        "type": "timeseries",
        "gridPos": {"x": 8, "y": 2, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{service=\"api\"}[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{service=\"api\"}[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{service=\"api\"}[5m]))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 4,
        "title": "HTTP Status Distribution",
        "type": "timeseries",
        "gridPos": {"x": 16, "y": 2, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{service=\"api\"}[1m])) by (status)",
            "legendFormat": "{{status}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 20}
          }
        }
      },
      {
        "id": 5,
        "title": "LLM Call Success Rate",
        "type": "gauge",
        "gridPos": {"x": 0, "y": 8, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "sum(rate(llm_call_success_total[5m])) / sum(rate(llm_call_total[5m]))",
            "legendFormat": "LLM Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.9},
                {"color": "green", "value": 0.98}
              ]
            },
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "id": 6,
        "title": "Active WebSocket Connections",
        "type": "timeseries",
        "gridPos": {"x": 4, "y": 8, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "ws_active_connections",
            "legendFormat": "Connections"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 500},
                {"color": "red", "value": 800}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "RabbitMQ Queue Depth",
        "type": "timeseries",
        "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "rabbitmq_queue_messages_ready{queue=~\"agent.*\"}",
            "legendFormat": "{{queue}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {"lineWidth": 2, "fillOpacity": 20}
          }
        }
      },
      {
        "id": 8,
        "title": "RAG Search Latency",
        "type": "timeseries",
        "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(rag_search_duration_seconds_bucket[5m]))",
            "legendFormat": "P95 Search Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"lineWidth": 2, "fillOpacity": 15}
          }
        }
      },
      {
        "id": 9,
        "title": "Milvus Collection Stats",
        "type": "stat",
        "gridPos": {"x": 0, "y": 14, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "milvus_num_entities{collection_name=\"knowledge_chunks\"}",
            "legendFormat": "Total Chunks"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 10,
        "title": "Redis Memory Usage",
        "type": "gauge",
        "gridPos": {"x": 4, "y": 14, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
            "legendFormat": "Memory %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "red", "value": 0.85}
              ]
            },
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "id": 11,
        "title": "Conversation Quality Score (LLM-as-Judge)",
        "type": "timeseries",
        "gridPos": {"x": 8, "y": 14, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "avg(rate(quality_score_sum[1h]) / rate(quality_score_count[1h])) by (dimension)",
            "legendFormat": "{{dimension}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "min": 0,
            "max": 5,
            "custom": {"lineWidth": 2, "fillOpacity": 15}
          }
        }
      },
      {
        "id": 12,
        "title": "Alert Events (Last 1h)",
        "type": "table",
        "gridPos": {"x": 16, "y": 14, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "ALERTS{alertstate=\"firing\"}",
            "format": "table"
          }
        ]
      }
    ]
  }
}
