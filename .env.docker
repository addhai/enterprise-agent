# Enterprise Agent — 生产环境变量
# 复制到 .env 后修改

# ============================================
# LLM 配置（阿里百炼 DashScope）
# ============================================
OPENAI_API_KEY=sk-22ed9fa230ec47c0b05993f229ee1b09
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agent
REDIS_URL=redis://redis:6379

# ============================================
# 向量数据库
# ============================================
CHROMA_PERSIST_DIR=/app/chroma_data

# ============================================
# Chatwoot 配置
# ============================================
CHATWOOT_SECRET_KEY=change-this-to-random-string-in-production

# ============================================
# LangSmith 追踪（可选）
# ============================================
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=enterprise-agent
LANGSMITH_TRACING=false
