# =============================================================================
# Enterprise Agent — 环境变量模板
# 复制为 .env 后填入实际值
# =============================================================================

# ---- LLM / Embedding (阿里云百炼) ----
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_COMPLEX_MODEL=qwen-max
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# ---- LangSmith (可选，留空关闭) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=enterprise-agent
LANGSMITH_TRACING=false

# ---- 向量库后端 ----
# chroma | milvus | auto (Milvus 优先, Chroma 降级) | remote (调用 rag-service)
VECTOR_STORE_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=knowledge_base

# ---- Milvus ----
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=knowledge_chunks

# ---- PostgreSQL ----
POSTGRES_DB=agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- MinIO / S3 ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_DOCS=agent-docs
MINIO_BUCKET_LOGS=agent-logs
MINIO_BUCKET_MODELS=agent-models

# ---- RabbitMQ ----
RABBITMQ_USER=agent
RABBITMQ_PASS=agent
RABBITMQ_URL=amqp://agent:agent@localhost:5672
RABBITMQ_EXCHANGE=agent.tasks
RABBITMQ_INFERENCE_QUEUE=agent.inference.queue
RABBITMQ_PERSIST_QUEUE=memory.persist.queue
RABBITMQ_INDEX_QUEUE=rag.index.queue
RABBITMQ_NOTIFY_QUEUE=notify.push.queue

# ---- RAG Service (远程调用) ----
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_TIMEOUT=10.0

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Agent 配置 ----
MAX_REASONING_TURNS=5
MAX_TURNS_FAQ=1
MAX_TURNS_TECHNICAL=5
MAX_TURNS_COMPLEX=8

# ---- Memory ----
MEMORY_CONTEXT_MAX_DOCS=3
SHORT_TERM_TTL=3600
SHORT_TERM_MAX_WINDOW=20
LONG_TERM_MAX_PER_USER=1000

# ---- Evaluation ----
EVAL_LLM_JUDGE_ENABLED=false
EVAL_ONLINE_SAMPLING_RATE=0.0
EVAL_HALLUCINATION_CHECK_ENABLED=true

# ---- Vision / OCR ----
VISION_ENGINE_NAME=qwen
VISION_MODEL=qwen-vl-plus
OCR_ENGINE_NAME=paddle
FALLBACK_OCR_NAME=tesseract

# ---- APISIX ----
APISIX_ADMIN_KEY=edd1c9f034335f136f87ad84b625c8f1

# ---- Grafana ----
GRAFANA_USER=admin
GRAFANA_PASS=admin
